# ---- Required ----
# Free Finnhub API key: https://finnhub.io/register
# Lives only on the server and is never sent to the browser.
# Finnhub's free tier is for personal, non-commercial use.
FINNHUB_KEY=

# ---- Server (optional) ----
PORT=8080
DATA_DIR=/data            # for local `npm start`, set to ./data
QUOTE_TTL=45              # seconds to cache a quote (cuts redundant Finnhub calls)

# ---- Crypto prices (optional) ----
# Crypto quotes come from CoinGecko and work with no key. For higher rate limits,
# get a free Demo key (no credit card) at https://www.coingecko.com/en/api and set
# it here; it stays server-side. Attribution to CoinGecko is shown in-app per their terms.
COINGECKO_KEY=

# ---- Notifications (optional) ----
CHECK_INTERVAL=60         # minutes between ceiling checks; 0 disables checks
NOTIFY_KIND=off           # ntfy | discord | webhook | off
# Where to POST the alert:
#   ntfy    -> https://ntfy.sh/your-unique-topic   (install the ntfy app, subscribe to the topic)
#   discord -> your channel's webhook URL
#   webhook -> any endpoint; receives JSON { title, body }
NOTIFY_URL=

# ---- History / drift (optional) ----
# Daily snapshot of each holding's weight, powering the sparkline + 30-day drift.
HISTORY=on               # set to 'off' to disable

# ---- Authentication (optional) ----
# Set a password to require a login page. Leave blank to run open (LAN only).
# Forgot it? There's no reset flow by design — change this value and restart.
AUTH_PASSWORD=
# Signs session cookies. Set a long random string (e.g. `openssl rand -hex 32`)
# so logins survive restarts. If blank, one is generated at startup and
# sessions reset whenever the container restarts.
SESSION_SECRET=
# Set true only if you serve TrimPoint over HTTPS (adds the Secure cookie flag).
COOKIE_SECURE=false
